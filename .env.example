# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development          # set to "production" to enable security guards
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_URL=postgresql+asyncpg://lexicon:change_me_in_production@localhost:5432/living_lexicon
POSTGRES_SYNC_URL=postgresql://lexicon:change_me_in_production@localhost:5432/living_lexicon

# PostgreSQL connection pool (optional – defaults shown)
PG_POOL_SIZE=10
PG_MAX_OVERFLOW=20
PG_POOL_RECYCLE=1800         # seconds before idle connections are recycled

# Auto-create tables on startup (dev convenience; use migrations in production)
AUTO_CREATE_TABLES=false

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_production

# ─── Ollama / LLM ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── API Security ─────────────────────────────────────────────────────────────
# Enable write/admin endpoints (POST /ingest, PUT /pg/word, etc.)
ENABLE_WRITE_ENDPOINTS=false
# Required when ENABLE_WRITE_ENDPOINTS=true
ADMIN_API_TOKEN=

# Optional: require X-API-Key header on all non-public routes
REQUIRE_API_KEY=false
PUBLIC_API_KEY=

# Rate limiting (requests per minute per IP; 0 = disabled)
RATE_LIMIT_PER_MINUTE=120

# Set true only when running behind a reverse proxy that sets X-Forwarded-For
TRUSTED_PROXY=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production: must NOT be "*" or the app will refuse to start.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*
